#!/bin/sh
set -eu

env_file="${HERMES_ENV_FILE:-.env.local}"

if [ "${1:-}" = "--env" ]; then
  if [ $# -lt 2 ]; then
    echo "usage: ssh-hermes-vps [--env PATH] [remote-command]" >&2
    exit 2
  fi
  env_file="$2"
  shift 2
fi

if [ ! -f "$env_file" ]; then
  echo "ssh-hermes-vps: env file not found: $env_file" >&2
  exit 1
fi

case "$env_file" in
  /*) ;;
  *) env_file="$(pwd)/$env_file" ;;
esac

host="$(awk '/^SSH_HOST=/{print substr($0,10); exit}' "$env_file")"
user="$(awk '/^SSH_USER=/{print substr($0,10); exit}' "$env_file")"
key="$(awk '/^SSH_KEY=/{print substr($0,9); exit}' "$env_file")"
has_pass="$(awk '/^SSH_PASS=/{if (length(substr($0,10)) > 0) print "yes"; exit}' "$env_file")"

if [ -z "$host" ]; then
  echo "ssh-hermes-vps: SSH_HOST is missing in $env_file" >&2
  exit 1
fi

if [ -z "$has_pass" ] && [ -z "$key" ]; then
  echo "ssh-hermes-vps: SSH_KEY or SSH_PASS is missing in $env_file" >&2
  exit 1
fi

if [ -z "$user" ]; then
  user="chowmesadmin"
fi

if [ -n "$key" ]; then
  case "$key" in
    "~/"*) key="$HOME/${key#~/}" ;;
  esac
fi

case "$host" in
  *@*) target="$host" ;;
  *) target="$user@$host" ;;
esac

ssh_auth_opts=""
if [ -n "$key" ]; then
  ssh_auth_opts="-i $key -o BatchMode=yes"
else
  askpass="$(mktemp /tmp/hermes_ssh_askpass.XXXXXX)"
  cleanup() {
    rm -f "$askpass"
  }
  trap cleanup EXIT INT TERM

  cat > "$askpass" <<'EOF'
#!/bin/sh
awk '/^SSH_PASS=/{print substr($0,10); exit}' "$HERMES_ENV_FILE"
EOF
  chmod 700 "$askpass"

  export HERMES_ENV_FILE="$env_file"
  export SSH_ASKPASS="$askpass"
  export SSH_ASKPASS_REQUIRE=force
  export DISPLAY=none
  ssh_auth_opts="-o BatchMode=no -o PreferredAuthentications=password -o PubkeyAuthentication=no -o NumberOfPasswordPrompts=1"
fi

# shellcheck disable=SC2086

ssh \
  $ssh_auth_opts \
  -o StrictHostKeyChecking=accept-new \
  -o UserKnownHostsFile=/tmp/hermes_vps_known_hosts \
  -o ConnectTimeout=10 \
  "$target" "$@"
