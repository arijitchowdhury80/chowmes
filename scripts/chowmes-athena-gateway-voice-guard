#!/bin/sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ssh_helper="$script_dir/chowmes-ssh-helper"
runtime="$script_dir/chowmes-athena-gateway-voice-guard-runtime"
mode="--check"
restart=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check)
      mode="--check"
      ;;
    --apply)
      mode="--apply"
      ;;
    --restart-gateway)
      restart=1
      ;;
    -h|--help)
      cat <<'EOF'
Usage: scripts/chowmes-athena-gateway-voice-guard [--check|--apply] [--restart-gateway]

Verifies or reapplies the Chowmes live Hermes gateway voice guard:
- Athena-style provider failure messages.
- Deterministic Telegram greeting-only replies.

Default mode is --check. Use --apply after Hermes updates or container rebuilds
if /opt/hermes/gateway/run.py has lost the Chowmes guard.
EOF
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

if [ ! -f "$runtime" ]; then
  echo "missing runtime script: $runtime" >&2
  exit 1
fi

(
  cd "$script_dir"
  COPYFILE_DISABLE=1 tar --no-xattrs -cf - chowmes-athena-gateway-voice-guard-runtime
) |
  "$ssh_helper" "sudo docker exec -i hermes /bin/sh -lc 'tar --no-xattrs -xf - -C /opt/data/scripts && rm -f /opt/data/scripts/._chowmes-athena-gateway-voice-guard-runtime && chown hermes:hermes /opt/data/scripts/chowmes-athena-gateway-voice-guard-runtime && chmod 755 /opt/data/scripts/chowmes-athena-gateway-voice-guard-runtime'"

"$ssh_helper" "sudo docker exec -i hermes /opt/data/scripts/chowmes-athena-gateway-voice-guard-runtime $mode"

if [ "$mode" = "--apply" ] && [ "$restart" = "1" ]; then
  "$ssh_helper" "sudo docker exec -i hermes /bin/sh -lc '/package/admin/s6-2.15.0.0/command/s6-svc -t /run/service/gateway-default'"
fi
