#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.request
from decimal import Decimal, InvalidOperation
from pathlib import Path


REPO_ENV = Path("/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/.env.local")
REMOTE_ENV = Path("/opt/data/.env")
REMOTE_CONFIG = Path("/opt/data/config.yaml")


def load_env_file(path: Path) -> None:
    if not path.exists():
        return
    for raw in path.read_text(errors="replace").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip().strip('"').strip("'")
        if key and key not in os.environ:
            os.environ[key] = value


def run_remote() -> int:
    script_dir = Path(__file__).resolve().parent
    ssh_helper = script_dir / "chowmes-ssh-helper"
    env_file = os.environ.get("HERMES_ENV_FILE", str(REPO_ENV))
    if not ssh_helper.exists():
        print("Chowmes provider watch failed: local SSH helper is missing.")
        print(f"Action: run from the ChowMes repository or check {ssh_helper}.")
        return 75
    command = "sudo docker exec -i hermes /opt/data/scripts/chowmes-provider-credit-watch"
    return subprocess.call([str(ssh_helper), "--env", env_file, command])


def money(value) -> Decimal:
    try:
        return Decimal(str(value))
    except (InvalidOperation, ValueError):
        return Decimal("0")


def active_provider() -> str:
    override = os.environ.get("CHOWMES_MODEL_PROVIDER", "").strip().lower()
    if override:
        return override
    if REMOTE_CONFIG.exists():
        text = REMOTE_CONFIG.read_text(errors="replace")
        in_model = False
        for raw in text.splitlines():
            line = raw.rstrip()
            if line == "model:":
                in_model = True
                continue
            if in_model and line and not line.startswith(" "):
                in_model = False
            if in_model:
                match = re.match(r"\s+provider:\s*['\"]?([^'\"]+)['\"]?\s*$", line)
                if match:
                    return match.group(1).strip().lower()
    return "openrouter"


def check_gemini() -> int:
    api_key = (os.environ.get("GEMINI_API_KEY") or os.environ.get("GOOGLE_API_KEY") or "").strip()
    if not api_key:
        print("Chowmes provider watch failed: Gemini API key is missing.")
        print("Effect: Athena, Vulcan, CI synthesis, and Gemini-backed agents may fail.")
        print("Action: restore GEMINI_API_KEY or GOOGLE_API_KEY in the Hermes runtime environment.")
        return 75

    model = os.environ.get("CHOWMES_GEMINI_WATCH_MODEL", "gemini-2.5-flash")
    payload = {
        "contents": [{"parts": [{"text": "Reply with OK."}]}],
        "generationConfig": {"temperature": 0, "maxOutputTokens": 8},
    }
    request = urllib.request.Request(
        f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={api_key}",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(request, timeout=20) as response:
            json.loads(response.read().decode("utf-8"))
    except Exception as exc:
        print("Chowmes provider watch failed: Gemini API check failed.")
        print(f"Reason: {type(exc).__name__}: {str(exc)[:240]}")
        print("Effect: Athena, Vulcan, CI synthesis, and Gemini-backed agents may fail.")
        print("Action: check Gemini API billing/key/model access before the next scheduled run.")
        return 75
    return 0


def check_openrouter() -> int:
    api_key = os.environ.get("OPENROUTER_API_KEY", "").strip()
    if not api_key:
        print("Chowmes provider watch failed: OPENROUTER_API_KEY is missing.")
        return 75

    floor = money(os.environ.get("CHOWMES_OPENROUTER_CREDIT_FLOOR", "5.00"))
    request = urllib.request.Request(
        "https://openrouter.ai/api/v1/credits",
        headers={"Authorization": "Bearer " + api_key},
    )

    try:
        with urllib.request.urlopen(request, timeout=15) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except Exception as exc:
        print("Chowmes provider watch failed: OpenRouter credit check failed.")
        print(f"Reason: {type(exc).__name__}: {str(exc)[:240]}")
        return 75

    data = payload.get("data") or payload
    total = money(data.get("total_credits"))
    used = money(data.get("total_usage"))
    remaining = total - used

    if remaining < floor:
        print("Chowmes provider credit alert")
        print(f"OpenRouter remaining=${remaining:.4f}; floor=${floor:.4f}.")
        print("Effect: OpenRouter-backed agents may fail.")
        print("Action: add OpenRouter credits or switch provider/model before the next scheduled run.")
        return 75
    return 0


def check_algolia_inference() -> int:
    base_url = os.environ.get("ALGOLIA_INFERENCE_BASE_URL", "").strip().rstrip("/")
    api_key = os.environ.get("ALGOLIA_INFERENCE_API_KEY", "").strip()
    model = (
        os.environ.get("CHOWMES_ALGOLIA_INFERENCE_WATCH_MODEL")
        or os.environ.get("ALGOLIA_INFERENCE_MODEL")
        or ""
    ).strip()

    missing = [
        name
        for name, value in {
            "ALGOLIA_INFERENCE_BASE_URL": base_url,
            "ALGOLIA_INFERENCE_API_KEY": api_key,
            "ALGOLIA_INFERENCE_MODEL": model,
        }.items()
        if not value
    ]
    if missing:
        print("Chowmes provider watch failed: Algolia inference config is incomplete.")
        print("Missing: " + ", ".join(missing))
        print("Effect: low-end Algolia inference routing cannot be enabled safely.")
        print("Action: add the missing env vars, then rerun this health check before routing traffic.")
        return 75

    payload = {
        "model": model,
        "messages": [{"role": "user", "content": "Reply exactly OK."}],
        "temperature": 0,
        "max_tokens": 8,
    }
    request = urllib.request.Request(
        f"{base_url}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Authorization": "Bearer " + api_key,
            "Content-Type": "application/json",
            "User-Agent": "Chowmes-Hermes/1.0",
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=20) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")[:240]
        print("Chowmes provider watch failed: Algolia inference API check failed.")
        print(f"Reason: HTTP {exc.code}: {body}")
        print("Effect: low-end Algolia inference routing is not safe to enable.")
        print("Action: verify endpoint URL, API key, model id, and OpenAI-compatible chat/completions support.")
        return 75
    except Exception as exc:
        print("Chowmes provider watch failed: Algolia inference API check failed.")
        print(f"Reason: {type(exc).__name__}: {str(exc)[:240]}")
        print("Effect: low-end Algolia inference routing is not safe to enable.")
        print("Action: verify endpoint reachability from the Chowmes VPS.")
        return 75

    if not (payload.get("choices") or payload.get("output") or payload.get("response")):
        print("Chowmes provider watch failed: Algolia inference returned an unexpected response shape.")
        print("Effect: Hermes may not understand this endpoint as an OpenAI-compatible chat provider.")
        print("Action: confirm the endpoint's wire protocol before routing traffic.")
        return 75
    return 0


def main() -> int:
    if REMOTE_ENV.exists():
        load_env_file(REMOTE_ENV)
    elif os.environ.get("CHOWMES_PROVIDER_WATCH_NO_REMOTE") != "1":
        return run_remote()

    provider = active_provider()
    if os.environ.get("CHOWMES_CHECK_ALGOLIA_INFERENCE", "").strip().lower() in {"1", "true", "yes"}:
        algolia_status = check_algolia_inference()
        if algolia_status:
            return algolia_status

    if provider in {"gemini", "google", "google-gemini", "google-ai-studio"}:
        return check_gemini()
    if provider == "openrouter":
        return check_openrouter()
    if provider in {"algolia-inference", "algolia_inference", "algolia"}:
        return check_algolia_inference()

    print(f"Chowmes provider watch failed: unsupported active provider '{provider}'.")
    print("Action: update chowmes-provider-credit-watch to validate this provider before relying on scheduled agents.")
    return 75


if __name__ == "__main__":
    raise SystemExit(main())
