#!/bin/sh
set -eu

repair=0
send_test=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repair)
      repair=1
      ;;
    --send-test)
      send_test=1
      ;;
    -h|--help)
      cat <<'EOF'
Usage: chowmes-health-check [--repair] [--send-test]

Container-native Chowmes health check. This runs inside the Hermes container
and verifies runtime ownership, config readability, gateway status, web backend,
recent permission errors, and optional Telegram delivery.
EOF
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

current_user="$(id -un)"
setuidgid="$(command -v s6-setuidgid 2>/dev/null || true)"
if [ -z "$setuidgid" ]; then
  setuidgid="/package/admin/s6-2.15.0.0/command/s6-setuidgid"
fi

as_hermes() {
  if [ "$current_user" = "hermes" ]; then
    "$@"
    return
  fi
  if [ ! -x "$setuidgid" ]; then
    echo "s6-setuidgid_not_found"
    exit 1
  fi
  "$setuidgid" hermes "$@"
}

if [ "$repair" = "1" ]; then
  if [ "$(id -u)" != "0" ]; then
    echo "repair=unavailable"
    echo "repair_blocker=must run as root to repair ownership"
    exit 1
  fi
  chown -R hermes:hermes /opt/data
  chmod 700 /opt/data
  [ -f /opt/data/.env ] && chmod 600 /opt/data/.env
  [ -f /opt/data/config.yaml ] && chmod 640 /opt/data/config.yaml
  echo "repair=applied"
else
  echo "repair=skipped"
fi

echo "== hermes-user-read =="
if as_hermes sh -lc 'test -x /opt/data && test -r /opt/data/.env && test -r /opt/data/config.yaml'; then
  echo "hermes_can_read_runtime_files=yes"
else
  echo "hermes_can_read_runtime_files=no"
  exit 1
fi

echo "== ownership-drift =="
drift="$(find /opt/data -xdev ! -user hermes -print | head -n 20)"
if [ -n "$drift" ]; then
  echo "$drift"
  echo "root_owned_runtime_files=yes"
  exit 1
fi
echo "root_owned_runtime_files=no"

echo "== gateway-status =="
as_hermes /opt/hermes/.venv/bin/hermes gateway status

echo "== cron-status =="
as_hermes /opt/hermes/.venv/bin/hermes cron list | sed -n '/competitive-research-daily/,+7p;/competitive-research-weekly/,+7p;/chowmes-provider-credit-watch/,+7p'

echo "== ci-audit-status =="
as_hermes python3 - <<'PY'
import json
from pathlib import Path

root = Path("/opt/data/knowledge/obsidian/MyOS/Projects/Competitive Intelligence/artifacts/competitive-research/run-audits")
for name in ["2026-06-29-daily.json", "2026-06-29-weekly.json"]:
    path = root / name
    if not path.exists():
        print(f"{name}=missing")
        continue
    data = json.loads(path.read_text())
    print(f"{name}={data.get('status')}")
PY

echo "== argus-status =="
if [ -d /opt/data/profiles/argus ]; then
  echo "argus_profile=present"
  if awk -F= '
    /^[A-Za-z_][A-Za-z0-9_]*=/ {
      key=$1
      if (key ~ /^(TELEGRAM_BOT_TOKEN|ARGUS_BOT_TOKEN|ARGUS_TELEGRAM_BOT_TOKEN)$/) {
        found=1
      }
    }
    END { exit found ? 0 : 1 }
  ' /opt/data/profiles/argus/.env 2>/dev/null; then
    echo "argus_telegram_token_key=present"
  else
    echo "argus_telegram_token_key=missing"
  fi
  argus_gateway="$(as_hermes /opt/hermes/.venv/bin/hermes -p argus gateway status 2>/dev/null | awk '/Gateway:/ {print $2; exit}')"
  echo "argus_gateway=${argus_gateway:-unknown}"
  if [ "${argus_gateway:-}" = "running" ]; then
    echo "argus_activation_ready=yes"
  else
    echo "argus_activation_ready=no"
    echo "argus_activation_blocker=dedicated Argus Telegram bot token/channel is not configured or gateway is not running"
  fi
else
  echo "argus_profile=missing"
  echo "argus_activation_ready=no"
fi

echo "== web-backend =="
if as_hermes sh -lc 'cd /opt/hermes && /opt/hermes/.venv/bin/python -m tools.web_tools' | sed -n '1,8p'; then
  :
else
  echo "web_backend_check=failed"
  exit 1
fi

echo "== recent-permission-errors =="
if tail -n 120 /opt/data/logs/gateways/default/current 2>/dev/null | grep -q "PermissionError"; then
  echo "permission_errors_seen_in_recent_log=yes"
else
  echo "permission_errors_seen_in_recent_log=no"
fi

if [ "$send_test" = "1" ]; then
  echo "== telegram-send-test =="
  as_hermes /opt/hermes/.venv/bin/hermes send --to telegram "Chowmes health check passed: gateway, permissions, CI audits, and web backend are healthy."
fi

echo "chowmes_health_check=pass"
