except FileNotFoundError:
    data = {}

removed = []
for key, value in list(data.items()):
    origin = value.get('origin') or {}
    is_target = (
        value.get('platform') == 'telegram'
        and value.get('chat_type') == 'dm'
        and (
            origin.get('chat_id') == channel_id
            or origin.get('user_id') == channel_id
            or key.endswith('telegram:dm:' + channel_id)
        )
    )
    if is_target:
        session_id = value.get('session_id')
        if session_id:
            removed.append(session_id)
        data.pop(key, None)

sessions_path.write_text((json.dumps(data, indent=2) if data else '{}') + '\n')

for session_id in removed:
    subprocess.run(
        ['/opt/hermes/.venv/bin/hermes', 'sessions', 'delete', session_id, '--yes'],
        check=False,
    )

print('cleared_sessions=' + ','.join(removed))
PY

/opt/hermes/.venv/bin/hermes gateway restart
cat /opt/data/sessions/sessions.json
REMOTE
