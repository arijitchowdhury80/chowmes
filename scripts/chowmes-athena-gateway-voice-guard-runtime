#!/bin/sh
set -eu

mode="--check"
gateway_run="${GATEWAY_RUN_PATH:-/opt/hermes/gateway/run.py}"
python_bin="${PYTHON_BIN:-/opt/hermes/.venv/bin/python}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check|--apply)
      mode="$1"
      ;;
    -h|--help)
      cat <<'EOF'
Usage: chowmes-athena-gateway-voice-guard-runtime [--check|--apply]

Container-native verifier/patcher for the Chowmes Athena gateway voice guard.
Use GATEWAY_RUN_PATH to test against a fixture.
EOF
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
  shift
done

if [ ! -f "$gateway_run" ]; then
  echo "gateway_run_path=$gateway_run"
  echo "athena_gateway_voice_guard=missing"
  echo "athena_gateway_voice_guard_blocker=gateway run.py not found"
  exit 2
fi

if [ ! -x "$python_bin" ]; then
  python_bin="python3"
fi

"$python_bin" - "$mode" "$gateway_run" <<'PY'
from __future__ import annotations

import py_compile
import shutil
import sys
import time
from pathlib import Path

mode = sys.argv[1]
path = Path(sys.argv[2])

CONSTANTS = '''_ATHENA_CASUAL_GREETING_RE = re.compile(
    r"^\\s*(?:hi|hey|hello|yo|hiya|heya|what'?s\\s+up|sup|morning|good\\s+morning|good\\s+evening)[!.?\\s]*$",
    re.IGNORECASE,
)

_ATHENA_ROBOTIC_CASUAL_REPLY_RE = re.compile(
    r"\\b(?:what(?:'|’)?s on your mind|what(?:'|’)?s up\\??|how can i help|how may i assist|ready when you are|standing by)\\b",
    re.IGNORECASE,
)

_ATHENA_CASUAL_GREETING_REPLIES = (
    "Hey. I am here.",
    "Here. Already judging the machinery a little.",
    "Hey. I am with you.",
    "Present. Let us keep it clean today.",
)

'''

HELPER = '''def _athena_casual_greeting_reply(text: str) -> Optional[str]:
    """Return a deterministic Athena reply for tiny Telegram openers.

    Provider models kept drifting into generic helpdesk prompts for greetings
    like "hi" and "what's up".  This guard only catches low-context openers;
    anything substantive still goes to the agent.
    """
    body = str(text or "").strip()
    if not body or "\\n" in body or len(body) > 32:
        return None
    if not _ATHENA_CASUAL_GREETING_RE.match(body):
        return None
    index = sum(ord(ch) for ch in body.lower()) % len(_ATHENA_CASUAL_GREETING_REPLIES)
    return _ATHENA_CASUAL_GREETING_REPLIES[index]


def _athena_rewrite_robotic_casual_reply(text: str) -> Optional[str]:
    """Rewrite tiny generic assistant replies before Telegram delivery."""
    body = str(text or "").strip()
    if not body or "\\n" in body or len(body) > 140:
        return None
    if not _ATHENA_ROBOTIC_CASUAL_REPLY_RE.search(body):
        return None
    return _athena_casual_greeting_reply(text) or _ATHENA_CASUAL_GREETING_REPLIES[
        sum(ord(ch) for ch in body.lower()) % len(_ATHENA_CASUAL_GREETING_REPLIES)
    ]


'''

PROVIDER_OLD = '''def _gateway_provider_error_reply(text: str) -> str:
    """Map raw provider/API errors to a short user-safe Telegram reply."""
    if _GATEWAY_AUTH_ERROR_RE.search(text):
        return (
            "⚠️ Provider authentication failed. Check the configured credentials; "
            "raw provider details are in the gateway logs."
        )
    if _GATEWAY_PROVIDER_POLICY_RE.search(text):
        return (
            "⚠️ The model provider rejected the request. I kept the raw provider "
            "error out of chat; check gateway logs for details or try rephrasing."
        )
    if _GATEWAY_CREDIT_ERROR_RE.search(text):
        return (
            "Arijit, I’m blocked before I can think: OpenRouter credits are exhausted. "
            "Add credits or switch my provider/model, then message me again. "
            "I’ve kept the raw provider details in the gateway logs."
        )
    if _GATEWAY_RATE_LIMIT_RE.search(text):
        return "⏱️ The model provider is rate-limiting requests. Please wait a moment and try again."
    return (
        "⚠️ The model provider failed after retries. I kept raw provider details "
        "out of chat; check gateway logs for diagnostics."
    )
'''

PROVIDER_NEW = '''def _gateway_provider_error_reply(text: str) -> str:
    """Map raw provider/API errors to a short user-safe Telegram reply."""
    if _GATEWAY_AUTH_ERROR_RE.search(text):
        return (
            "Arijit, I cannot reach the active model because its credentials are failing. "
            "Effect: this reply stops before Athena can think. Next move: check the "
            "provider key or switch routes; the raw details are in the gateway logs."
        )
    if _GATEWAY_PROVIDER_POLICY_RE.search(text):
        return (
            "Arijit, the model provider rejected this before I could reason over it. "
            "Effect: the request did not reach Athena cleanly. Next move: try a "
            "different route or rephrase the request; the raw provider text stays in logs."
        )
    if _GATEWAY_CREDIT_ERROR_RE.search(text):
        return (
            "Arijit, the active model route is out of usable balance or below its "
            "credit floor. Effect: I cannot answer from this route. Next move: top "
            "up that provider or switch models; the raw provider details are in the "
            "gateway logs."
        )
    if _GATEWAY_RATE_LIMIT_RE.search(text):
        return (
            "Arijit, the active model route is throttling us. Give it a minute, then "
            "try again; if it repeats, move the session to a fallback route."
        )
    return (
        "Arijit, I hit the model provider before I could think. Effect: this reply "
        "stopped at infrastructure, not judgment. Next move: check the gateway logs "
        "and route health; I kept the raw provider details out of chat."
    )
'''

GUARD = '''        if (
            not is_internal
            and _gateway_platform_value(source.platform) == "telegram"
            and not event.media_urls
            and not event.get_command()
        ):
            _casual_reply = _athena_casual_greeting_reply(event.text)
            if _casual_reply:
                adapter = self.adapters.get(source.platform)
                if adapter:
                    await adapter.send(
                        source.chat_id,
                        _casual_reply,
                        metadata=self._thread_metadata_for_source(source),
                    )
                return None

'''


def status(src: str) -> dict[str, bool]:
    return {
        "constants": "_ATHENA_CASUAL_GREETING_RE = re.compile(" in src,
        "robotic_constants": "_ATHENA_ROBOTIC_CASUAL_REPLY_RE = re.compile(" in src,
        "helper": "def _athena_casual_greeting_reply(" in src,
        "robotic_helper": "def _athena_rewrite_robotic_casual_reply(" in src,
        "provider_voice": "the active model route is out of usable balance" in src
        and "OpenRouter credits are exhausted" not in src,
        "telegram_guard": "_athena_casual_greeting_reply(event.text)" in src,
        "final_voice": "_athena_rewrite_robotic_casual_reply(redacted)" in src,
    }


def report(flags: dict[str, bool]) -> None:
    print(f"gateway_run_path={path}")
    for key in [
        "constants",
        "robotic_constants",
        "helper",
        "robotic_helper",
        "provider_voice",
        "telegram_guard",
        "final_voice",
    ]:
        print(f"athena_gateway_voice_guard_{key}={'present' if flags[key] else 'missing'}")
    print(
        "athena_gateway_voice_guard="
        + ("present" if all(flags.values()) else "missing")
    )


def patch(src: str) -> str:
    changed = False

    if "_ATHENA_CASUAL_GREETING_RE = re.compile(" not in src:
        anchor = "_GATEWAY_SECRET_PATTERNS = ("
        start = src.find(anchor)
        if start == -1:
            raise SystemExit("patch_blocker=secret pattern anchor not found")
        end = src.find("\n\n", start)
        if end == -1:
            raise SystemExit("patch_blocker=secret pattern block end not found")
        src = src[: end + 2] + CONSTANTS + src[end + 2 :]
        changed = True
    elif "_ATHENA_ROBOTIC_CASUAL_REPLY_RE = re.compile(" not in src:
        start = src.find("_ATHENA_CASUAL_GREETING_REPLIES = (")
        if start == -1:
            raise SystemExit("patch_blocker=casual replies anchor not found")
        end = src.find("\n\n", start)
        if end == -1:
            raise SystemExit("patch_blocker=casual replies block end not found")
        robotic_constant = '''_ATHENA_ROBOTIC_CASUAL_REPLY_RE = re.compile(
    r"\\b(?:what(?:'|’)?s on your mind|what(?:'|’)?s up\\??|how can i help|how may i assist|ready when you are|standing by)\\b",
    re.IGNORECASE,
)

'''
        src = src[:start] + robotic_constant + src[start:]
        changed = True

    if "def _athena_casual_greeting_reply(" not in src:
        anchor = "\ndef _gateway_provider_error_reply(text: str) -> str:\n"
        if anchor not in src:
            raise SystemExit("patch_blocker=provider function anchor not found")
        src = src.replace(anchor, "\n" + HELPER + anchor.lstrip(), 1)
        changed = True
    elif "def _athena_rewrite_robotic_casual_reply(" not in src:
        anchor = "\ndef _gateway_provider_error_reply(text: str) -> str:\n"
        if anchor not in src:
            raise SystemExit("patch_blocker=provider function anchor not found")
        robotic_helper = '''def _athena_rewrite_robotic_casual_reply(text: str) -> Optional[str]:
    """Rewrite tiny generic assistant replies before Telegram delivery."""
    body = str(text or "").strip()
    if not body or "\\n" in body or len(body) > 140:
        return None
    if not _ATHENA_ROBOTIC_CASUAL_REPLY_RE.search(body):
        return None
    return _athena_casual_greeting_reply(text) or _ATHENA_CASUAL_GREETING_REPLIES[
        sum(ord(ch) for ch in body.lower()) % len(_ATHENA_CASUAL_GREETING_REPLIES)
    ]


'''
        src = src.replace(anchor, "\n" + robotic_helper + anchor.lstrip(), 1)
        changed = True

    if "OpenRouter credits are exhausted" in src:
        if PROVIDER_OLD not in src:
            raise SystemExit("patch_blocker=provider function shape changed")
        src = src.replace(PROVIDER_OLD, PROVIDER_NEW, 1)
        changed = True

    if "_athena_rewrite_robotic_casual_reply(redacted)" not in src:
        anchor = (
            "    if _looks_like_gateway_provider_error(redacted):\n"
            "        return _gateway_provider_error_reply(redacted)\n"
            "    return redacted\n"
        )
        if anchor not in src:
            raise SystemExit("patch_blocker=final response sanitizer anchor not found")
        replacement = (
            "    if _looks_like_gateway_provider_error(redacted):\n"
            "        return _gateway_provider_error_reply(redacted)\n"
            "    robotic_reply = _athena_rewrite_robotic_casual_reply(redacted)\n"
            "    if robotic_reply:\n"
            "        return robotic_reply\n"
            "    return redacted\n"
        )
        src = src.replace(anchor, replacement, 1)
        changed = True

    if "_athena_casual_greeting_reply(event.text)" not in src:
        anchor = (
            "            return None\n"
            "        \n"
            "        # Intercept messages that are responses to a pending /update prompt.\n"
        )
        if anchor not in src:
            anchor = (
                "            return None\n"
                "\n"
                "        # Intercept messages that are responses to a pending /update prompt.\n"
            )
        if anchor not in src:
            raise SystemExit("patch_blocker=message handler insertion anchor not found")
        src = src.replace(
            anchor,
            "            return None\n\n" + GUARD
            + "        # Intercept messages that are responses to a pending /update prompt.\n",
            1,
        )
        changed = True

    if not changed:
        print("athena_gateway_voice_guard_apply=noop")
    return src


source = path.read_text()
flags = status(source)
report(flags)

if mode == "--check":
    raise SystemExit(0 if all(flags.values()) else 2)

backup = path.with_name(path.name + ".bak.athena-voice-guard-" + time.strftime("%Y%m%d%H%M%S"))
new_source = patch(source)
new_flags = status(new_source)
if not all(new_flags.values()):
    report(new_flags)
    raise SystemExit("patch_failed=voice guard still incomplete")

if new_source == source:
    print("athena_gateway_voice_guard_apply=present")
    raise SystemExit(0)

shutil.copy2(path, backup)
path.write_text(new_source)
py_compile.compile(str(path), doraise=True)
print(f"backup_path={backup}")
print("athena_gateway_voice_guard_apply=patched")
report(new_flags)
PY
