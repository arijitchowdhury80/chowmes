#!/bin/sh
set -eu

if [ "$#" -ne 1 ]; then
  cat >&2 <<'EOF'
Usage: scripts/sync-obsidian-path-from-hermes "Relative/Path/In/MyOS"

Example:
  scripts/sync-obsidian-path-from-hermes "Knowledge/Print-on-Demand/The-ONLY-Print-on-Demand-Guide-You-Need-for-2026"
EOF
  exit 2
fi

relative_path="$1"
case "$relative_path" in
  /*|*..*|"")
    echo "refusing unsafe relative path: $relative_path" >&2
    exit 1
    ;;
esac

vault_root="${OBSIDIAN_VAULT_ROOT:-/Users/arijitchowdhury/Dropbox/AI-Development/Personal/Obsidian-Vault/MyOS}"
env_file="${HERMES_ENV_FILE:-/Users/arijitchowdhury/Dropbox/AI-Development/Personal/ChowMes/.env.local}"
script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ssh_helper="$script_dir/chowmes-ssh-helper"

mkdir -p "$vault_root"

"$ssh_helper" --env "$env_file" "sudo docker exec hermes sh -lc 'cd /opt/data/knowledge/obsidian/MyOS && if [ -e \"$relative_path\" ]; then tar -czf - \"$relative_path\"; else echo \"missing path: $relative_path\" >&2; exit 1; fi'" | tar -xzf - -C "$vault_root"

echo "synced_from_hermes=$vault_root/$relative_path"
